[Unit]
Description=HappyDo Guard Deploy Webhook
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/opt/HappyDoGuard/deploy
ExecStart=/usr/bin/node /opt/HappyDoGuard/deploy/webhook.js
Restart=always
RestartSec=5
Environment=WEBHOOK_PORT=9000
Environment=DEPLOY_BRANCH=main
EnvironmentFile=-/opt/HappyDoGuard/.env

[Install]
WantedBy=multi-user.target
